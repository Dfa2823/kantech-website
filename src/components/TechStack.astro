    name: 'Railway',
    color: '#FFFFFF',
    svg: `<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path d="M14 8L14 40M24 8L24 40M34 8L34 40" stroke="#94A3B8" stroke-width="2" stroke-linecap="round"/><path d="M10 16h28M10 24h28M10 32h28" stroke="#94A3B8" stroke-width="2" stroke-linecap="round"/></svg>`,
