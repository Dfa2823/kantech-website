    name: 'Docker',
    color: '#2496ED',
    svg: `<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="18" width="7" height="6" rx="1" stroke="#2496ED" stroke-width="1.5" fill="none"/><rect x="14" y="18" width="7" height="6" rx="1" stroke="#2496ED" stroke-width="1.5" fill="none"/><rect x="22" y="18" width="7" height="6" rx="1" stroke="#2496ED" stroke-width="1.5" fill="none"/><rect x="14" y="11" width="7" height="6" rx="1" stroke="#2496ED" stroke-width="1.5" fill="none"/><rect x="22" y="11" width="7" height="6" rx="1" stroke="#2496ED" stroke-width="1.5" fill="none"/><path d="M2 27c3-3 6-3 8-2s5 1 8 0 7-1 10 0 5 3 7 3c4 0 7-2 8-4" stroke="#2496ED" stroke-width="2.5" fill="none" stroke-linecap="round"/></svg>`,
