---
<section class="py-16 border-y border-k-border/40 overflow-hidden bg-k-surface/20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-10" data-animate>
      <p class="section-label mb-3">
        <span data-lang="es">Stack Tecnologico</span>
        <span data-lang="en">Tech Stack</span>
      </p>
      <h2 class="font-display text-2xl md:text-3xl font-bold text-k-text mb-3">
        <span data-lang="es">Tecnologías que dominamos</span>
        <span data-lang="en">Technologies we master</span>
      </h2>
      <p class="text-k-muted text-sm max-w-xl mx-auto">
        <span data-lang="es">Herramientas modernas y probadas para construir soluciones robustas, escalables y mantenibles.</span>
        <span data-lang="en">Modern, proven tools to build robust, scalable, and maintainable solutions.</span>
      </p>
    </div>

    <div class="grid grid-cols-2 min-[400px]:grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3 sm:gap-4" data-animate>
      {techs.map((t, i) => (
        <div class="group flex flex-col items-center gap-3 p-4 rounded-2xl bg-k-card border border-k-border hover:border-k-blue/30 transition-all duration-300 hover:shadow-lg hover:shadow-k-blue/5"
             style={`animation-delay: ${i * 0.05}s`}>
          <div class="w-12 h-12 flex items-center justify-center flex-shrink-0 transition-transform duration-300 group-hover:scale-110">
            <Fragment set:html={t.svg} />
          </div>
          <span class="text-k-muted text-xs font-medium text-center group-hover:text-k-text transition-colors">{t.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
