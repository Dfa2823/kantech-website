---
const techs = [
  { name: 'N8N',         color: '#EA4B71' },
  { name: 'React',       color: '#61DAFB' },
  { name: 'Node.js',     color: '#68A063' },
  { name: 'Python',      color: '#3776AB' },
  { name: '.NET / C#',   color: '#512BD4' },
  { name: 'PostgreSQL',  color: '#336791' },
  { name: 'TypeScript',  color: '#3178C6' },
  { name: 'Odoo',        color: '#714B67' },
  { name: 'Next.js',     color: '#FFFFFF' },
  { name: 'Astro',       color: '#FF5D01' },
  { name: 'Docker',      color: '#2496ED' },
  { name: 'Railway',     color: '#0B0D0E' },
];
---
<section class="py-10 border-y border-k-border/40 overflow-hidden bg-k-surface/20">
  <div class="max-w-7xl mx-auto px-6">
    <p class="text-center text-xs font-semibold text-k-muted tracking-widest uppercase mb-6">
      <span data-lang="es">Tecnologías que dominamos</span>
      <span data-lang="en">Technologies we master</span>
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      {techs.map(t => (
        <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-k-surface border border-k-border hover:border-k-blue/40 transition-colors duration-200 group">
          <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background: ${t.color}`}></span>
          <span class="text-k-muted group-hover:text-k-text text-xs font-medium transition-colors">{t.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
