---
const year = new Date().getFullYear();
const links = [
  { href: '#servicios', labelEs: 'Servicios', labelEn: 'Services' },
  { href: '#portafolio', labelEs: 'Portafolio', labelEn: 'Portfolio' },
  { href: '#proceso', labelEs: 'Proceso', labelEn: 'Process' },
  { href: '#nosotros', labelEs: 'Nosotros', labelEn: 'About' },
  { href: '#contacto', labelEs: 'Contacto', labelEn: 'Contact' },
];
---
<footer class="border-t border-k-border bg-k-surface/20">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid md:grid-cols-3 gap-8 mb-10">

      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-gradient-to-br from-k-blue to-k-purple shadow-lg shadow-k-blue/30">
            <svg width="16" height="16" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 8h3v7.5l7-7.5h4L15 17l8 7h-4.5l-6.5-5.8V24H9V8z" fill="white"/>
            </svg>
          </div>
          <span class="font-display font-bold text-k-text text-lg tracking-tight">KANTECH</span>
        </a>
        <p class="text-k-muted text-sm leading-relaxed mb-4 max-w-xs">
          <span data-lang="es">Agentes de IA, automatizaciones y desarrollo a medida para empresas en crecimiento.</span>
          <span data-lang="en">AI agents, automations, and custom software for growing businesses.</span>
        </p>
        <!-- Social -->
        <div class="flex items-center gap-3">
          <a href="https://www.linkedin.com/in/diegoalpala/" target="_blank" rel="noopener"
             class="w-11 h-11 rounded-lg border border-k-border flex items-center justify-center text-k-muted hover:text-k-cyan hover:border-k-cyan transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://github.com/Dfa2823" target="_blank" rel="noopener"
             class="w-11 h-11 rounded-lg border border-k-border flex items-center justify-center text-k-muted hover:text-k-text hover:border-k-text transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a href="https://wa.me/573194436045" target="_blank" rel="noopener"
             class="w-11 h-11 rounded-lg border border-k-border flex items-center justify-center text-k-muted hover:text-green-400 hover:border-green-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.122 1.532 5.854L.057 23.886a.5.5 0 0 0 .613.613l6.033-1.475A11.955 11.955 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.641-.516-5.148-1.413l-.369-.214-3.822.936.955-3.822-.237-.383A9.963 9.963 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav links -->
      <div>
        <h4 class="font-semibold text-k-text text-sm mb-4">
          <span data-lang="es">Navegación</span>
          <span data-lang="en">Navigation</span>
        </h4>
        <ul class="space-y-2.5">
          {links.map(l => (
            <li>
              <a href={l.href} class="text-k-muted hover:text-k-text text-sm transition-colors">
                <span data-lang="es">{l.labelEs}</span>
                <span data-lang="en">{l.labelEn}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact quick -->
      <div>
        <h4 class="font-semibold text-k-text text-sm mb-4">
          <span data-lang="es">Contacto directo</span>
          <span data-lang="en">Direct contact</span>
        </h4>
        <ul class="space-y-3">
          <li>
            <a href="https://wa.me/573194436045" target="_blank" rel="noopener"
               class="flex items-center gap-2 text-k-muted hover:text-k-green transition-colors text-sm">
              <span class="text-k-green">●</span> +57 319 443 6045
            </a>
          </li>
          <li>
            <a href="mailto:diegoalpala422@gmail.com"
               class="flex items-center gap-2 text-k-muted hover:text-k-text transition-colors text-sm">
              <span class="text-k-blue">●</span> diegoalpala422@gmail.com
            </a>
          </li>
          <li>
            <span class="flex items-center gap-2 text-k-muted text-sm">
              <span class="text-k-purple">●</span>
              <span data-lang="es">Cali, Colombia · Disponible LatAm</span>
              <span data-lang="en">Cali, Colombia · Available LatAm</span>
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-k-border/50 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-k-muted text-xs">
        © {year} KANTECH.
        <span data-lang="es">Todos los derechos reservados.</span>
        <span data-lang="en">All rights reserved.</span>
      </p>
      <p class="text-k-muted text-xs">
        <span data-lang="es">Hecho con precisión en Colombia 🇨🇴</span>
        <span data-lang="en">Crafted with precision in Colombia 🇨🇴</span>
      </p>
    </div>
  </div>
</footer>
