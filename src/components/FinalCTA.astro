<section class="relative py-20 px-6 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(30,59,255,0.08) 0%, rgba(108,47,217,0.06) 50%, rgba(0,212,255,0.04) 100%);"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] rounded-full blur-3xl opacity-20"
         style="background: radial-gradient(circle, #1E3BFF, transparent 70%);"></div>
  </div>

  <div class="relative z-10 max-w-3xl mx-auto text-center" data-animate>
    <h2 class="font-display text-3xl md:text-4xl font-bold text-k-text leading-tight mb-4">
      <span data-lang="es">Tu competencia ya se esta<br/><span class="gradient-text">automatizando.</span></span>
      <span data-lang="en">Your competitors are already<br/><span class="gradient-text">automating.</span></span>
    </h2>
    <p class="text-k-muted text-lg mb-8 max-w-xl mx-auto">
      <span data-lang="es">Cada dia sin automatizar es dinero y tiempo que pierdes. Agenda una llamada de 30 minutos y te mostramos como empezar.</span>
      <span data-lang="en">Every day without automation is money and time lost. Book a 30-minute call and we'll show you how to start.</span>
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="https://wa.me/573194436045?text=Hola%2C%20quiero%20agendar%20un%20diagn%C3%B3stico%20gratuito%20con%20KANTECH"
         target="_blank" rel="noopener"
         class="btn-primary text-base py-4 px-10">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.122 1.532 5.854L.057 23.886a.5.5 0 0 0 .613.613l6.033-1.475A11.955 11.955 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.641-.516-5.148-1.413l-.369-.214-3.822.936.955-3.822-.237-.383A9.963 9.963 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
        </svg>
        <span data-lang="es">Agendar diagnostico gratis</span>
        <span data-lang="en">Book a free diagnosis</span>
      </a>
      <a href="#portafolio" class="btn-outline text-base py-4 px-10">
        <span data-lang="es">Ver resultados reales</span>
        <span data-lang="en">See real results</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
