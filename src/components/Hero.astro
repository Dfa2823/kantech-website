---
---
<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden grid-dot-bg pt-16">

  <!-- Background orbs -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full opacity-20 blur-3xl animate-pulse-slow"
         style="background: radial-gradient(circle, #1E3BFF 0%, transparent 70%);"></div>
    <div class="absolute bottom-1/3 right-1/4 w-80 h-80 rounded-full opacity-15 blur-3xl animate-pulse-slow delay-300"
         style="background: radial-gradient(circle, #6C2FD9 0%, transparent 70%);"></div>
    <div class="absolute top-1/2 right-1/3 w-64 h-64 rounded-full opacity-10 blur-3xl animate-pulse-slow delay-600"
         style="background: radial-gradient(circle, #00D4FF 0%, transparent 70%);"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-k-blue/30 bg-k-blue/10 text-k-cyan text-xs font-semibold tracking-wider uppercase mb-8 animate-fade-up">
      <span class="w-1.5 h-1.5 rounded-full bg-k-green animate-pulse"></span>
      <span data-lang="es">Nuestros clientes ahorran $3-5M COP/mes · Diagnóstico gratis</span>
      <span data-lang="en">Our clients save $700-1,200 USD/mo · Free diagnosis</span>
    </div>

    <!-- Headline -->
    <h1 class="font-display text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-k-text leading-[1.1] mb-4 sm:mb-6 animate-fade-up delay-100">
      <span data-lang="es">
        Deja de perder horas<br/>
        <span class="gradient-text">en tareas manuales.</span>
      </span>
      <span data-lang="en">
        Stop wasting hours<br/>
        <span class="gradient-text">on manual tasks.</span>
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="text-k-muted text-base sm:text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-6 sm:mb-10 animate-fade-up delay-200">
      <span data-lang="es">
        Tu equipo pierde +20 horas semanales copiando datos, enviando reportes y apagando incendios.
        Lo solucionamos con IA y automatizaciones — desde $500.000 COP, con resultados visibles en semanas.
      </span>
      <span data-lang="en">
        Your team wastes 20+ hours per week copying data, sending reports, and putting out fires.
        We fix it with AI and automations — from ~$120 USD, with visible results in weeks.
      </span>
    </p>

    <!-- Service tags -->
    <div class="hidden sm:flex flex-wrap justify-center gap-2 mb-10 animate-fade-up delay-300">
      {[
        { es: 'Agentes de IA', en: 'AI Agents' },
        { es: 'Automatizaciones', en: 'Automations' },
        { es: 'Mejoras de Proceso', en: 'Process Improvement' },
        { es: 'Desarrollo a Medida', en: 'Custom Development' },
      ].map(tag => (
        <span class="px-3 py-1 rounded-full text-xs font-medium border border-k-border text-k-muted bg-k-surface/50">
          <span data-lang="es">{tag.es}</span>
          <span data-lang="en">{tag.en}</span>
        </span>
      ))}
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up delay-400">
      <a href="https://wa.me/573194436045?text=Hola%2C%20me%20interesa%20conocer%20m%C3%A1s%20sobre%20los%20servicios%20de%20KANTECH"
         target="_blank" rel="noopener"
         class="btn-primary text-base py-3.5 px-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.122 1.532 5.854L.057 23.886a.5.5 0 0 0 .613.613l6.033-1.475A11.955 11.955 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.641-.516-5.148-1.413l-.369-.214-3.822.936.955-3.822-.237-.383A9.963 9.963 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
        </svg>
        <span data-lang="es">Quiero mi diagnóstico gratis</span>
        <span data-lang="en">Get my free diagnosis</span>
      </a>
      <a href="#portafolio" class="btn-outline text-base py-3.5 px-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        <span data-lang="es">Ver casos de éxito reales</span>
        <span data-lang="en">See real success stories</span>
      </a>
    </div>

    <!-- Stats with animated counters -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 md:gap-16 mt-12 sm:mt-16 pt-8 sm:pt-10 border-t border-k-border/50 animate-fade-up delay-500 text-center">
      <div class="text-center">
        <div class="font-display text-3xl font-bold gradient-text"><span data-counter="500">0</span>+</div>
        <div class="text-k-muted text-sm mt-1">
          <span data-lang="es">Horas/mes automatizadas</span>
          <span data-lang="en">Hours/month automated</span>
        </div>
      </div>
      <div class="text-center">
        <div class="font-display text-3xl font-bold gradient-text"><span data-counter="4">0</span></div>
        <div class="text-k-muted text-sm mt-1">
          <span data-lang="es">Países en producción</span>
          <span data-lang="en">Countries in production</span>
        </div>
      </div>
      <div class="text-center">
        <div class="font-display text-3xl font-bold gradient-text"><span data-counter="10">0</span>+</div>
        <div class="text-k-muted text-sm mt-1">
          <span data-lang="es">Sistemas en producción</span>
          <span data-lang="en">Systems in production</span>
        </div>
      </div>
      <div class="text-center">
        <div class="font-display text-3xl font-bold gradient-text"><span data-counter="98">0</span>%</div>
        <div class="text-k-muted text-sm mt-1">
          <span data-lang="es">Clientes satisfechos</span>
          <span data-lang="en">Client satisfaction</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce opacity-40">
    <span class="text-k-muted text-xs">scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-k-muted">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>
