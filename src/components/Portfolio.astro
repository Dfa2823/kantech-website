---
<section id="portafolio" class="py-24 px-6 bg-k-surface/30">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <div class="section-label mb-4">
        <span data-lang="es">Portafolio</span>
        <span data-lang="en">Portfolio</span>
      </div>
      <h2 class="section-title mb-4">
        <span data-lang="es">Casos de éxito <span class="gradient-text">reales.</span></span>
        <span data-lang="en">Real success <span class="gradient-text">stories.</span></span>
      </h2>
      <p class="section-sub mx-auto">
        <span data-lang="es">Proyectos entregados en producción. Tecnología construida para resolver problemas concretos de negocios reales.</span>
        <span data-lang="en">Production-ready projects delivered. Technology built to solve concrete problems for real businesses.</span>
      </p>
    </div>

    <!-- Cases grid -->
    <div class="grid md:grid-cols-2 gap-6">
      {cases.map((c, i) => (
        <div class="card-glass group relative overflow-hidden flex flex-col" data-animate style={`animation-delay: ${i * 0.12}s`}>

          <!-- Glow -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-2xl"
               style={`background: radial-gradient(ellipse at top left, ${c.glow}, transparent 65%)`}></div>

          <div class="relative z-10 flex flex-col h-full">
            <!-- Top row -->
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center border border-k-border flex-shrink-0"
                     style={`color: ${c.color}; background: ${c.glow}`}>
                  <Fragment set:html={c.icon} />
                </div>
                <div>
                  <span class="text-xs font-semibold px-2 py-0.5 rounded-full border"
                        style={`color: ${c.color}; border-color: ${c.color}30; background: ${c.glow}`}>
                    <span data-lang="es">{c.sector}</span>
                    <span data-lang="en">{c.sectorEn}</span>
                  </span>
                </div>
              </div>
            </div>

            <!-- Title -->
            <h3 class="font-display text-lg font-bold text-k-text mb-3">
              <span data-lang="es">{c.name}</span>
              <span data-lang="en">{c.nameEn}</span>
            </h3>

            <!-- Description -->
            <p class="text-k-muted text-sm leading-relaxed mb-5 flex-1">
              <span data-lang="es">{c.descEs}</span>
              <span data-lang="en">{c.descEn}</span>
            </p>

            <!-- Stack -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {c.stack.map(t => (
                <span class="px-2 py-0.5 rounded text-xs font-mono font-medium bg-k-bg border border-k-border text-k-muted">
                  {t}
                </span>
              ))}
            </div>

            <!-- Result -->
            <div class="flex items-start gap-2 pt-4 border-t border-k-border/50">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                   stroke={c.color} stroke-width="2.5" class="mt-0.5 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <p class="text-xs leading-relaxed" style={`color: ${c.color}`}>
                <span data-lang="es">{c.resultEs}</span>
                <span data-lang="en">{c.resultEn}</span>
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA bottom -->
    <div class="text-center mt-12" data-animate>
      <p class="text-k-muted text-sm mb-4">
        <span data-lang="es">¿Tienes un proyecto en mente?</span>
        <span data-lang="en">Have a project in mind?</span>
      </p>
      <a href="https://wa.me/573194436045?text=Hola%2C%20quiero%20hablar%20sobre%20un%20proyecto"
         target="_blank" rel="noopener" class="btn-primary">
        <span data-lang="es">Cuéntanos tu reto</span>
        <span data-lang="en">Tell us your challenge</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>
