---
---
<section id="contacto" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <div class="section-label mb-4">
        <span data-lang="es">Contacto</span>
        <span data-lang="en">Contact</span>
      </div>
      <h2 class="section-title mb-4">
        <span data-lang="es">¿Listo para transformar<br/>tu empresa?</span>
        <span data-lang="en">Ready to transform<br/>your business?</span>
      </h2>
      <p class="section-sub mx-auto">
        <span data-lang="es">Cuéntanos tu reto. En menos de 24 horas te respondemos con una propuesta inicial.</span>
        <span data-lang="en">Tell us your challenge. We'll respond within 24 hours with an initial proposal.</span>
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 items-start">

      <!-- Left: contact info -->
      <div class="space-y-6" data-animate>

        <!-- WhatsApp -->
        <a href="https://wa.me/573194436045?text=Hola%2C%20quiero%20hablar%20sobre%20un%20proyecto%20con%20KANTECH"
           target="_blank" rel="noopener"
           class="flex items-center gap-4 p-5 bg-k-surface border border-k-border rounded-2xl
                  hover:border-green-500/50 hover:shadow-lg hover:shadow-green-500/10 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-green-500/10 border border-green-500/20 text-green-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.122 1.532 5.854L.057 23.886a.5.5 0 0 0 .613.613l6.033-1.475A11.955 11.955 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.641-.516-5.148-1.413l-.369-.214-3.822.936.955-3.822-.237-.383A9.963 9.963 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-k-muted mb-0.5">WhatsApp</p>
            <p class="text-k-text font-semibold group-hover:text-green-400 transition-colors">+57 319 443 6045</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-k-muted group-hover:text-green-400 transition-colors">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>

        <!-- Email -->
        <a href="mailto:diegoalpala422@gmail.com?subject=Proyecto%20KANTECH"
           class="flex items-center gap-4 p-5 bg-k-surface border border-k-border rounded-2xl
                  hover:border-k-blue/50 hover:shadow-lg hover:shadow-k-blue/10 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-k-blue/10 border border-k-blue/20 text-k-blue flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-k-muted mb-0.5">Email</p>
            <p class="text-k-text font-semibold group-hover:text-k-blue transition-colors">diegoalpala422@gmail.com</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-k-muted group-hover:text-k-blue transition-colors">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/in/diegoalpala/" target="_blank" rel="noopener"
           class="flex items-center gap-4 p-5 bg-k-surface border border-k-border rounded-2xl
                  hover:border-blue-400/50 hover:shadow-lg hover:shadow-blue-400/10 transition-all duration-300 group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-blue-500/10 border border-blue-500/20 text-blue-400 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-k-muted mb-0.5">LinkedIn</p>
            <p class="text-k-text font-semibold group-hover:text-blue-400 transition-colors">Diego Alpala — KANTECH</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ml-auto text-k-muted group-hover:text-blue-400 transition-colors">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>

        <!-- Availability badge -->
        <div class="flex items-center gap-3 p-4 bg-k-green/5 border border-k-green/20 rounded-xl">
          <span class="w-2.5 h-2.5 rounded-full bg-k-green animate-pulse flex-shrink-0"></span>
          <p class="text-k-green text-sm font-medium">
            <span data-lang="es">Disponible para nuevos proyectos · Colombia · LatAm</span>
            <span data-lang="en">Available for new projects · Colombia · LatAm</span>
          </p>
        </div>
      </div>

      <!-- Right: form -->
      <div class="bg-k-surface border border-k-border rounded-2xl p-5 sm:p-8" data-animate>
        <h3 class="font-display font-bold text-k-text text-lg mb-6">
          <span data-lang="es">Cuéntanos tu proyecto</span>
          <span data-lang="en">Tell us about your project</span>
        </h3>

        <form id="contact-form" class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-k-muted mb-1.5">
                <span data-lang="es">Nombre</span><span data-lang="en">Name</span>
              </label>
              <input type="text" name="name" required
                     class="w-full bg-k-bg border border-k-border rounded-xl px-4 py-3 text-sm text-k-text
                            placeholder:text-k-muted/50 focus:outline-none focus:border-k-blue transition-colors"
                     placeholder="Tu nombre" />
            </div>
            <div>
              <label class="block text-xs font-medium text-k-muted mb-1.5">
                <span data-lang="es">Empresa</span><span data-lang="en">Company</span>
              </label>
              <input type="text" name="company"
                     class="w-full bg-k-bg border border-k-border rounded-xl px-4 py-3 text-sm text-k-text
                            placeholder:text-k-muted/50 focus:outline-none focus:border-k-blue transition-colors"
                     placeholder="Tu empresa" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-medium text-k-muted mb-1.5">
              <span data-lang="es">Servicio de interés</span><span data-lang="en">Service of interest</span>
            </label>
            <select name="service"
                    class="w-full bg-k-bg border border-k-border rounded-xl px-4 py-3 text-sm text-k-text
                           focus:outline-none focus:border-k-blue transition-colors">
              <option value="" data-lang="es">Selecciona un servicio...</option>
              <option value="ia" data-lang="es">Agentes de IA</option>
              <option value="auto" data-lang="es">Automatizaciones N8N</option>
              <option value="proceso" data-lang="es">Mejoras de Proceso</option>
              <option value="dev" data-lang="es">Desarrollo a Medida</option>
              <option value="otro" data-lang="es">Otro / No sé aún</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-medium text-k-muted mb-1.5">
              <span data-lang="es">¿Cuál es tu reto?</span><span data-lang="en">What's your challenge?</span>
            </label>
            <textarea name="message" rows="4" required
                      class="w-full bg-k-bg border border-k-border rounded-xl px-4 py-3 text-sm text-k-text
                             placeholder:text-k-muted/50 focus:outline-none focus:border-k-blue transition-colors resize-none"
                      placeholder="Describe brevemente el problema que quieres resolver..."></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center py-3.5">
            <span data-lang="es">Enviar por WhatsApp</span>
            <span data-lang="en">Send via WhatsApp</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('contact-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const name = this.name.value;
    const company = this.company.value;
    const service = this.service.value;
    const message = this.message.value;
    const text = `Hola, soy ${name}${company ? ' de ' + company : ''}. Me interesa: ${service || 'sus servicios'}. ${message}`;
    window.open('https://wa.me/573194436045?text=' + encodeURIComponent(text), '_blank');
  });
</script>
