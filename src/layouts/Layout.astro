---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const siteUrl = 'https://kantech-website-production.up.railway.app';
const {
  title = 'KANTECH | Agentes de IA, Automatizaciones y Software a Medida — Colombia',
  description = 'Empresa de tecnologia en Cali, Colombia. Desarrollamos agentes de IA, automatizaciones con N8N y software a medida (CRM, ERP) para empresas en Colombia y Latinoamerica. Resultados en semanas, no meses.',
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="KANTECH" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: preconnect + stylesheet (no blocking @import) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- JSON-LD: ProfessionalService + Services -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "KANTECH",
      "description": "Agentes de IA, automatizaciones con N8N y desarrollo de software a medida para empresas en Colombia y Latinoamerica.",
      "url": "https://kantech-website-production.up.railway.app",
      "telephone": "+573194436045",
      "email": "diegoalpala422@gmail.com",
      "logo": "https://kantech-website-production.up.railway.app/favicon.svg",
      "image": "https://kantech-website-production.up.railway.app/og-image.png",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Cali",
        "addressRegion": "Valle del Cauca",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "3.4516",
        "longitude": "-76.5320"
      },
      "areaServed": [
        {"@type": "Country", "name": "Colombia"},
        {"@type": "Country", "name": "Ecuador"},
        {"@type": "Country", "name": "Peru"},
        {"@type": "Country", "name": "Mexico"}
      ],
      "knowsAbout": ["Inteligencia Artificial", "Agentes de IA", "Automatizacion de Procesos", "N8N", "Desarrollo de Software a Medida", "CRM", "ERP", "Chatbots empresariales"],
      "sameAs": ["https://www.linkedin.com/in/diegoalpala/", "https://github.com/Dfa2823"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios KANTECH",
        "itemListElement": [
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Agentes de IA", "description": "Asistentes inteligentes que atienden clientes, califican leads y gestionan flujos de trabajo 24/7."}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Automatizaciones con N8N", "description": "Flujos de automatizacion personalizados que conectan CRMs, ERPs, WhatsApp y APIs externas."}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Mejoras de Proceso", "description": "Analisis y rediseno de operaciones internas para eliminar cuellos de botella y reducir costos."}},
          {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Desarrollo de Software a Medida", "description": "CRM, ERP, sistemas web y apps construidos exactamente para tu negocio."}}
        ]
      }
    }
    </script>

    <!-- JSON-LD: FAQPage (rich snippets en Google) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type": "Question", "name": "Cuanto cuesta un proyecto con KANTECH?", "acceptedAnswer": {"@type": "Answer", "text": "Cada proyecto es diferente. Tenemos servicios desde $500.000 COP para automatizaciones puntuales, hasta sistemas completos a medida (CRM, ERP). Siempre entregamos una propuesta clara con alcance y precio antes de empezar."}},
        {"@type": "Question", "name": "Cuanto tiempo tarda un proyecto?", "acceptedAnswer": {"@type": "Answer", "text": "Las automatizaciones pueden estar listas en 1-2 semanas. Un sistema completo como un CRM o ERP puede tomar entre 4 y 12 semanas segun el alcance."}},
        {"@type": "Question", "name": "Necesito saber de tecnologia para trabajar con KANTECH?", "acceptedAnswer": {"@type": "Answer", "text": "No. Nos encargamos de toda la parte tecnica. Tu nos explicas el problema de negocio y nosotros lo traducimos en una solucion tecnologica."}},
        {"@type": "Question", "name": "Que pasa despues de que entregan el proyecto?", "acceptedAnswer": {"@type": "Answer", "text": "Ofrecemos soporte continuo, mantenimiento y evolucion del sistema. No somos un proveedor de un solo proyecto, somos tu socio tecnologico a largo plazo."}},
        {"@type": "Question", "name": "Trabajan solo con empresas en Colombia?", "acceptedAnswer": {"@type": "Answer", "text": "No. Trabajamos con empresas en Colombia, Ecuador, Peru, Mexico y cualquier pais de Latinoamerica. Todos los proyectos pueden gestionarse 100% remoto."}},
        {"@type": "Question", "name": "Pueden integrar sistemas como Siigo, Odoo o WhatsApp?", "acceptedAnswer": {"@type": "Answer", "text": "Si. La integracion entre sistemas es uno de nuestros puntos fuertes. Conectamos Siigo, Odoo, WhatsApp Business, Google Workspace y cualquier plataforma con API."}}
      ]
    }
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      // Language switcher
      function setLang(lang) {
        document.querySelectorAll('[data-lang]').forEach(el => {
          el.style.display = el.dataset.lang === lang ? '' : 'none';
        });
        document.querySelectorAll('[data-lang-btn]').forEach(btn => {
          const active = btn.dataset.langBtn === lang;
          btn.classList.toggle('text-k-text', active);
          btn.classList.toggle('font-bold', active);
          btn.classList.toggle('text-k-muted', !active);
        });
        try { localStorage.setItem('kantech-lang', lang); } catch(e) {}
      }

      // On load: restore saved language
      (function() {
        let saved = 'es';
        try { saved = localStorage.getItem('kantech-lang') || 'es'; } catch(e) {}
        if (saved === 'en') setLang('en');
      })();

      // Intersection Observer for scroll animations
      document.addEventListener('DOMContentLoaded', () => {
        const els = document.querySelectorAll('[data-animate]');
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('animate-fade-up');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.1 });
        els.forEach(el => { el.style.opacity = '0'; io.observe(el); });

        // Animated counters
        const counters = document.querySelectorAll('[data-counter]');
        const counterIO = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target;
              const target = parseInt(el.dataset.counter, 10);
              if (target === 0) { el.textContent = '0'; counterIO.unobserve(el); return; }
              const duration = 1500;
              const start = performance.now();
              function tick(now) {
                const p = Math.min((now - start) / duration, 1);
                const ease = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.round(target * ease);
                if (p < 1) requestAnimationFrame(tick);
              }
              requestAnimationFrame(tick);
              counterIO.unobserve(el);
            }
          });
        }, { threshold: 0.3 });
        counters.forEach(c => counterIO.observe(c));

        // Cursor glow on cards
        document.querySelectorAll('.card-glow').forEach(card => {
          card.addEventListener('mousemove', e => {
            const r = card.getBoundingClientRect();
            card.style.setProperty('--x', (e.clientX - r.left) + 'px');
            card.style.setProperty('--y', (e.clientY - r.top) + 'px');
          });
        });

        // Active nav link on scroll
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('header a[href^="#"]');
        const navIO = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              navLinks.forEach(link => {
                link.classList.toggle('text-k-text', link.getAttribute('href') === '#' + id);
                link.classList.toggle('text-k-muted', link.getAttribute('href') !== '#' + id);
              });
            }
          });
        }, { rootMargin: '-40% 0px -55% 0px' });
        sections.forEach(s => navIO.observe(s));
      });
    </script>
  </body>
</html>
