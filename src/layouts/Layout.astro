---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'KANTECH — Tu empresa en modo automático',
  description = 'Desarrollamos agentes de IA, automatizaciones y software a medida para empresas que quieren crecer sin complicarse.',
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://kantech-website-production.up.railway.app" />
    <meta property="og:image" content="https://kantech-website-production.up.railway.app/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://kantech-website-production.up.railway.app/og-image.svg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "KANTECH",
      "description": "Agentes de IA, automatizaciones y desarrollo de software a medida para empresas en crecimiento.",
      "url": "https://kantech.com.co",
      "telephone": "+573194436045",
      "email": "diegoalpala422@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Cali",
        "addressCountry": "CO"
      },
      "areaServed": ["CO", "EC", "PE", "MX"],
      "knowsAbout": ["Inteligencia Artificial", "Automatización de Procesos", "Desarrollo de Software", "N8N", "CRM", "ERP"],
      "sameAs": ["https://www.linkedin.com/in/diegoalpala/", "https://github.com/Dfa2823"]
    }
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      // Language switcher
      function setLang(lang) {
        document.querySelectorAll('[data-lang]').forEach(el => {
          el.style.display = el.dataset.lang === lang ? '' : 'none';
        });
        document.querySelectorAll('[data-lang-btn]').forEach(btn => {
          const active = btn.dataset.langBtn === lang;
          btn.classList.toggle('text-k-text', active);
          btn.classList.toggle('font-bold', active);
          btn.classList.toggle('text-k-muted', !active);
        });
        try { localStorage.setItem('kantech-lang', lang); } catch(e) {}
      }

      // On load: restore saved language
      (function() {
        let saved = 'es';
        try { saved = localStorage.getItem('kantech-lang') || 'es'; } catch(e) {}
        if (saved === 'en') setLang('en');
      })();

      // Intersection Observer for scroll animations
      document.addEventListener('DOMContentLoaded', () => {
        const els = document.querySelectorAll('[data-animate]');
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('animate-fade-up');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.1 });
        els.forEach(el => { el.style.opacity = '0'; io.observe(el); });
      });
    </script>
  </body>
</html>
